<idea-plugin>
    <id>com.github.filiplabs.devpulse</id>
    <name>DevPulse</name>
    <vendor>filip-labs</vendor>
    <description><![CDATA[
        <p><b>DevPulse</b> tracks your coding focus, edit activity, and Pomodoro sessions directly inside the IDE.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="DevPulse"
                factoryClass="com.github.filiplabs.devpulse.toolWindow.DevPulseToolWindowFactory"
                icon="/icons/devpulseToolWindow.svg"/>
        <postStartupActivity implementation="com.github.filiplabs.devpulse.startup.DevPulseStartupActivity"/>
    </extensions>
</idea-plugin>
